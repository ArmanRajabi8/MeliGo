{
  "manifest_version": 3,
  "name": "MeliGo Universal Cart",
  "version": "1.0",
  "description": "Save product info to MeliGo shopping cart.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Save product to MeliGo",
    "default_popup": "popup.html"
  },
 "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
]

}
